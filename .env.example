# Configuration OAuth GitHub
GITHUB_CLIENT_ID=votre_client_id_github
GITHUB_CLIENT_SECRET=votre_client_secret_github

# Configuration JWT
JWT_SECRET=planner-pro-super-secret-key-a-changer-en-production

# Clé de chiffrement AES-256-GCM (doit faire exactement 32 caractères)
ENCRYPTION_KEY=super-secret-key-32-bytes-long!

# Configuration Base de données
DATABASE_URL=mysql://root:root_password@localhost:3306/planner_pro

# Configuration Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Sécurité & CORS
CORS_ORIGINS=http://localhost:3000

# Variables d'environnement Frontend (à définir dans frontend/.env)
VITE_API_URL=http://localhost:3001
VITE_GITHUB_CLIENT_ID=votre_client_id_github

# Configuration des services réels (Optionnel pour le développement local)
# Si définis, l'application bascule sur les API réelles.
# GEMINI_API_KEY=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

