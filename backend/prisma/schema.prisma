// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  name              String?
  githubId          String?        @unique
  githubUsername    String?
  githubAccessToken String?
  ownedWorkspaces   Workspace[]    @relation("WorkspaceOwner")
  memberships       Membership[]
  projects          Project[]
  tasks             Task[]
  taskAssignments   TaskAssignee[]
  resourceProfiles  ResourceProfile[]
  resourceAllocations ResourceAllocation[]
  notes             Note[]
  refreshTokens     RefreshToken[]
  timeLogs          TimeLog[]
  sentInvitations   Invitation[]   @relation("SentInvitations")
  comments          Comment[]
  notifications     Notification[] @relation("UserNotifications")
  sentNotifications Notification[] @relation("SentNotifications")
  createdAt         DateTime       @default(now())
}

model Workspace {
  id          String       @id @default(uuid())
  name        String
  ownerId     String
  owner       User         @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  memberships Membership[]
  projects    Project[]
  teams       Team[]
  resourceProfiles ResourceProfile[]
  invitations   Invitation[]
  integrations  Integration[]
  sprints       Sprint[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  @@index([ownerId])
}

model Membership {
  id          String          @id @default(uuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id])
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  role        WorkspaceRole   @default(MEMBER)
  createdAt   DateTime        @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Team {
  id          String      @id @default(uuid())
  name        String
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([workspaceId])
}

model Project {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  githubRepo  String?   // Ex: "gaetan/planner-pro"
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  dueDate     DateTime?
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  phases      ProjectPhaseItem[]
  milestones  Milestone[]
  deliverables Deliverable[]
  deliveries  DeliveryRecord[]
  resourceAllocations ResourceAllocation[]
  tasks       Task[]
  invitations Invitation[]
  budgetCents  Int?
  billingType  String?   @default("TIME_AND_MATERIALS")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([userId])
  @@index([workspaceId])
}

model ProjectPhaseItem {
  id          String    @id @default(uuid())
  name        String
  status      PhaseStatus @default(NOT_STARTED)
  order       Int       @default(0)
  startDate   DateTime?
  dueDate     DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

model Milestone {
  id          String    @id @default(uuid())
  name        String
  description String?   @db.Text
  dueDate     DateTime?
  completedAt DateTime?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
}

model Deliverable {
  id          String            @id @default(uuid())
  title       String
  description String?           @db.Text
  status      DeliverableStatus @default(DRAFT)
  dueDate     DateTime?
  acceptedAt  DateTime?
  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([projectId])
}

model ResourceProfile {
  id                    String    @id @default(uuid())
  workspaceId           String
  workspace             Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  weeklyCapacityMinutes Int       @default(2400)
  skills                String?   @db.Text
  costRateCents         Int?
  billingRateCents      Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([workspaceId, userId])
  @@index([userId])
}

model ResourceAllocation {
  id                String   @id @default(uuid())
  projectId         String
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  allocationPercent Int      @default(100)
  roleLabel         String?
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([projectId])
  @@index([userId])
}

model DeliveryRecord {
  id          String         @id @default(uuid())
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status      DeliveryStatus @default(DRAFT)
  summary     String?        @db.Text
  deliveredAt DateTime?
  acceptedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  checklist   DeliveryChecklistItem[]

  @@index([projectId])
}

model DeliveryChecklistItem {
  id          String         @id @default(uuid())
  deliveryId  String
  delivery    DeliveryRecord @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  title       String
  checked     Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([deliveryId])
}

model Task {
  id          String         @id @default(uuid())
  title       String
  description String?        @db.Text
  status      TaskStatus     @default(TODO)
  priority    TaskPriority   @default(MEDIUM)
  startDate   DateTime?
  dueDate     DateTime?
  estimatedMinutes Int?
  progress    Int            @default(0)
  labels      String?        @db.Text
  projectId   String
  project     Project        @relation(fields: [projectId], references: [id])
  userId      String
  user        User           @relation(fields: [userId], references: [id])
  assignees   TaskAssignee[]
  dependencies TaskDependency[] @relation("TaskDependencies")
  dependents   TaskDependency[] @relation("TaskDependents")
  timeBlocks  TimeBlock[]
  timeLogs    TimeLog[]
  comments    Comment[]
  noteId      String?
  note        Note?          @relation(fields: [noteId], references: [id], onDelete: SetNull)
  sprintId    String?
  sprint      Sprint?        @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  storyPoints Int?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  @@index([projectId])
  @@index([userId])
  @@index([noteId])
  @@index([sprintId])
}

model TaskAssignee {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
  @@index([userId])
}

model TaskDependency {
  id              String   @id @default(uuid())
  taskId          String
  task            Task     @relation("TaskDependencies", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTaskId String
  dependsOnTask   Task     @relation("TaskDependents", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)
  type            DependencyType @default(FINISH_TO_START)
  createdAt       DateTime @default(now())

  @@unique([taskId, dependsOnTaskId])
  @@index([dependsOnTaskId])
}

model TimeBlock {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])

  @@index([taskId])
}

model TimeLog {
  id        String    @id @default(uuid())
  startTime DateTime
  endTime   DateTime?
  duration  Int?      // in seconds
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id])
  userId    String?
  user      User?     @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

model Note {
  id        String    @id @default(uuid())
  title     String
  content   String    @db.Text
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([userId])
}

model RefreshToken {
  id          String    @id @default(uuid())
  hashedToken String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

enum DeliveryStatus {
  DRAFT
  READY_FOR_ACCEPTANCE
  ACCEPTED
  REJECTED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  AT_RISK
  DELIVERED
  CLOSED
}

enum PhaseStatus {
  NOT_STARTED
  IN_PROGRESS
  DONE
}

enum DeliverableStatus {
  DRAFT
  READY_FOR_REVIEW
  ACCEPTED
  DELIVERED
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

model Invitation {
  id          String           @id @default(uuid())
  email       String?          // Facultatif pour les liens de partage
  tokenHash   String           @unique
  role        WorkspaceRole    @default(MEMBER)
  status      InvitationStatus @default(PENDING)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User             @relation("SentInvitations", fields: [invitedById], references: [id])
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId])
  @@index([invitedById])
  @@index([projectId])
}

model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@index([userId])
}

model Integration {
  id          String    @id @default(uuid())
  type        String    // "SLACK", "TEAMS", "GOOGLE_CALENDAR", "OUTLOOK"
  name        String
  url         String?   @db.Text
  calendarId  String?
  active      Boolean   @default(true)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Sprint {
  id          String       @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  status      SprintStatus @default(PLANNED)
  workspaceId String
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([workspaceId])
}

enum SprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  senderId    String?
  sender      User?    @relation("SentNotifications", fields: [senderId], references: [id])
  type        String   // "MENTION", "ASSIGNMENT", "SYSTEM", etc.
  title       String
  content     String   @db.Text
  read        Boolean  @default(false)
  taskId      String?
  projectId   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([senderId])
}


